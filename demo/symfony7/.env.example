# Demo environment template. Copy to .env (e.g. cp .env.example .env) and adjust.
# Do not commit .env. Required: APP_ENV, APP_SECRET, APP_DEBUG, DEFAULT_URI.

# Host port exposed by docker-compose for this demo.
PORT=8001

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_this_secret_key_to_a_random_value
APP_DEBUG=1
###< symfony/framework-bundle ###

###> symfony/routing ###
# Used when generating URLs in CLI (e.g. bin/console).
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=https://localhost:8001
###< symfony/routing ###

# Optional: when running behind a reverse proxy (e.g. Docker, nginx)
# TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
# TRUSTED_HOSTS='^localhost|example\.com$'
