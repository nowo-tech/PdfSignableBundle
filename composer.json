{
  "name": "nowo-tech/pdf-signable-bundle",
  "description": "Define signature box coordinates on PDFs in Symfony: form type with PDF.js viewer, drag-and-drop placement, validation, and signing hooks.",
  "type": "symfony-bundle",
  "license": "MIT",
  "keywords": [
    "symfony",
    "symfony-bundle",
    "pdf",
    "pdf-viewer",
    "pdfjs",
    "signature",
    "signature-coordinates",
    "document-signing",
    "form",
    "form-type",
    "coordinates",
    "signing",
    "eidas"
  ],
  "homepage": "https://github.com/nowo-tech/pdfSignableBundle",
  "support": {
    "issues": "https://github.com/nowo-tech/pdfSignableBundle/issues",
    "source": "https://github.com/nowo-tech/pdfSignableBundle",
    "docs": "https://github.com/nowo-tech/pdfSignableBundle/tree/HEAD/docs"
  },
  "authors": [
    {
      "name": "Héctor Franco Aceituno",
      "email": "hectorfranco@nowo.tech",
      "homepage": "https://github.com/HecFranco",
      "role": "Developer"
    },
    {
      "name": "Nowo.tech",
      "homepage": "https://nowo.tech"
    }
  ],
  "require": {
    "php": ">=8.1 <8.6",
    "symfony/framework-bundle": "^6.0 || ^7.0 || ^8.0",
    "symfony/form": "^6.0 || ^7.0 || ^8.0",
    "symfony/http-client": "^6.0 || ^7.0 || ^8.0",
    "symfony/process": "^6.0 || ^7.0 || ^8.0",
    "symfony/twig-bundle": "^6.0 || ^7.0 || ^8.0",
    "symfony/translation": "^6.0 || ^7.0 || ^8.0",
    "symfony/validator": "^6.0 || ^7.0 || ^8.0",
    "symfony/yaml": "^6.0 || ^7.0 || ^8.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-symfony": "^2.0",
    "phpunit/phpunit": "^10.0",
    "rector/rector": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Nowo\\PdfSignableBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nowo\\PdfSignableBundle\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.1.0"
    },
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "archive": {
    "exclude": ["/demo", "/.cursor"]
  },
  "scripts": {
    "test": "phpunit --color=always",
    "test-coverage": "phpunit --color=always --coverage-text --coverage-html coverage --coverage-clover coverage.xml",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "phpstan": "phpstan analyse --memory-limit=512M",
    "rector": "rector process",
    "rector-dry": "rector process --dry-run --no-progress-bar",
    "update": "composer update --no-interaction",
    "validate": "composer validate --strict",
    "qa": [
      "@cs-check",
      "@test"
    ],
    "validate-translations": "php .scripts/validate-translations-yaml.php"
  },
  "scripts-descriptions": {
    "test": "Run PHPUnit tests",
    "test-coverage": "Run PHPUnit tests with code coverage",
    "cs-check": "Check code style with PHP-CS-Fixer",
    "cs-fix": "Fix code style with PHP-CS-Fixer",
    "phpstan": "Run PHPStan static analysis",
    "rector": "Apply Rector refactoring",
    "rector-dry": "Run Rector in dry-run mode",
    "update": "Update composer.lock (composer update)",
    "validate": "Validate composer.json (composer validate --strict)",
    "qa": "Run all quality assurance checks",
    "validate-translations": "Validate translation YAML files"
  },
  "suggest": {
    "ext-yaml": "For faster YAML parsing (optional; Symfony Yaml is used)"
  }
}
