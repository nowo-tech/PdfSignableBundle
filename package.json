{
  "name": "nowo-tech/pdf-signable-bundle",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "tsc && vite build && VITE_ENTRY=acroform-editor vite build && pnpm run build:css",
    "build:dev": "tsc && vite build --mode development && VITE_ENTRY=acroform-editor vite build --mode development && pnpm run build:css",
    "copy-worker": "node .scripts/copy-pdf-worker.cjs",
    "postinstall": "node .scripts/copy-pdf-worker.cjs",
    "build:css": "sass src/Resources/assets/pdf-signable.scss src/Resources/public/js/pdf-signable.css --no-source-map",
    "dev": "vite build --watch",
    "watch": "vite build --watch",
    "clean": "rm -rf dist public/build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^29.0.2",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
